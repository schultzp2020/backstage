{
  "name": "@backstage/cli-module-oxlint",
  "version": "0.1.0",
  "description": "CLI module for oxlint integration in Backstage CLI",
  "backstage": {
    "role": "cli-module"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs.js"
      },
      "./defineBackstageConfig": "./config/defineBackstageConfig.ts",
      "./package.json": "./package.json"
    }
  },
  "homepage": "https://backstage.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/backstage/backstage",
    "directory": "packages/cli-module-oxlint"
  },
  "license": "Apache-2.0",
  "bin": "bin/backstage-cli-module-oxlint",
  "exports": {
    ".": "./src/index.ts",
    "./defineBackstageConfig": "./config/defineBackstageConfig.ts",
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "defineBackstageConfig": [
        "config/defineBackstageConfig.ts"
      ],
      "package.json": [
        "package.json"
      ]
    }
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "bin",
    "dist",
    "config"
  ],
  "scripts": {
    "build": "backstage-cli package build",
    "clean": "backstage-cli package clean",
    "lint": "backstage-cli package lint",
    "prepack": "backstage-cli package prepack",
    "postpack": "backstage-cli package postpack",
    "test": "backstage-cli package test"
  },
  "dependencies": {
    "@backstage/cli-common": "workspace:^",
    "@backstage/cli-node": "workspace:^",
    "@manypkg/get-packages": "^1.1.3",
    "cleye": "^2.3.0",
    "minimatch": "^10.0.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.22.1"
  },
  "devDependencies": {
    "@backstage/cli": "workspace:^"
  }
}
